# Agentic RAG Server 环境变量配置

# 服务配置
HOST=0.0.0.0
PORT=5010
DEBUG=false
LOG_LEVEL=INFO

# Milvus 连接（BaseVector-Core）
MILVUS_HOST=192.168.31.51
MILVUS_PORT=19530
MILVUS_USER=
MILVUS_PASSWORD=
MILVUS_DB_NAME=default

# 检索配置（BaseVector-Core）
#COLLECTION_NAME=papers_chunks_collection
COLLECTION_NAME=icau_papers_collection
TOP_K=10
RERANK_ENABLED=false
RERANK_MODEL_NAME=workspace/jina-reranker-v3
SIMILARITY_THRESHOLD=0.0
RETRIEVAL_CANDIDATE_MULTIPLIER=2
MILVUS_METRIC_TYPE=IP
MILVUS_NPROBE=10
KEYWORD_FTS_LANGUAGE=simple

# 向量编码模型（语义检索时使用）
EMBEDDING_MODEL=workspace/bge-base-zh-v1.5
# 向量维度（jina-embeddings-v5-text-small 为 1024，不填则自动从模型获取）
EMBEDDING_DIM=512

# BaseDB 服务配置
# 数据存储服务访问地址，例如：http://127.0.0.1:8001
DB_SERVICE_URL=http://192.168.31.51:5001

# 用于访问 BaseDB 的认证信息（通常为 JWT 或其他 Token）
DB_AUTHORIZATION=Bearer SYSTEM_TOKEN

# 文档/切片写入时使用的默认租户、所有者及密级
DB_TENANT_ID=1
DB_OWNER_ID=1
DB_SECURITY_LEVEL=1

# 文档默认状态（例如 indexed / active 等，需与后端约定保持一致）
DB_DOCUMENT_STATUS=active
